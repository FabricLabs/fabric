digraph FabricClasses {
  label = "Fabric class inheritances (@fabric/core — generated)"
  rankdir = "LR"

  // Regenerate: node scripts/classtree.js --write

  subgraph cluster_builtins {
    label = "Built-in / external bases"
    graph[style=dashed]
    "Object"
    "EventEmitter"
    "Buffer"
    "String"
    "HTTP"
  }

  "Buffer" -> "Signature"
  "EventEmitter" -> {
    "Actor"
    "Entity"
    "Key"
    "Reader"
    "Vector"
  }
  "Object" -> {
    "Bech32"
    "Buffer"
    "Codec"
    "Compiler"
    "Disk"
    "EncryptedPromise"
    "EventEmitter"
    "HKDF"
    "HTTP"
    "Hash256"
    "Network"
    "Observer"
    "Renderer"
    "String"
    "Token"
    "TypeTree"
    "Witness"
  }
  "String" -> "Path"
  "Actor" -> {
    "BitcoinBlock"
    "BitcoinTransaction"
    "Block"
    "Chain"
    "Circuit"
    "Filesystem"
    "History"
    "Identity"
    "Label"
    "Logger"
    "Machine"
    "Message"
    "Queue"
    "Remote"
    "Service"
    "State"
    "Store"
    "Swarm"
    "Transaction"
    "Tree"
  }
  "Circuit" -> {
    "Program"
    "RoundRobin"
  }
  "Contract" -> {
    "Bond"
    "Distribution"
    "Federation"
  }
  "EncryptedPromise" -> "Secret"
  "Entity" -> {
    "Capability"
    "Environment"
    "Session"
    "Transition"
  }
  "Fabric" -> "Validator"
  "FabricShell" -> "CLI"
  "HTTP" -> "Authority"
  "Message" -> "LightningMessage"
  "Service" -> {
    "Bitcoin"
    "Component"
    "Contract"
    "Exchange"
    "Fabric"
    "FabricShell"
    "Interface"
    "Lightning"
    "Local"
    "Node"
    "Peer"
    "Redis"
    "Text"
    "Turntable"
    "Wallet"
    "Worker"
    "ZMQ"
  }
  "Stack" -> {
    "Collection"
    "Script"
  }
  "State" -> {
    "Challenge"
    "Channel"
    "Document"
    "Instruction"
    "Ledger"
    "Router"
    "Stack"
  }
  "Store" -> {
    "Datastore"
    "Oracle"
    "Resource"
  }
}
